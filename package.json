{
  "name": "craft-kit",
  "version": "2.0.0",
  "description": "Zero-dependency toolkit for JavaScript and TypeScript: data structures, sorting/searching/DP/backtracking algorithms, Java-style utilities (Optional, Stream, Atomics, Collections) and security helpers. Framework-agnostic, dual ESM + CommonJS.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=16"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "typescript",
    "javascript",
    "utilities",
    "algorithms",
    "data-structures",
    "sorting",
    "searching",
    "dynamic-programming",
    "backtracking",
    "stack",
    "queue",
    "linked-list",
    "heap",
    "binary-search-tree",
    "hash-table",
    "optional",
    "stream",
    "atomic",
    "collections",
    "hashmap",
    "treemap",
    "password",
    "pbkdf2",
    "hashing",
    "security",
    "esm",
    "commonjs"
  ],
  "author": "sorodriguezz",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.19.43",
    "tsup": "^8.0.0",
    "typescript": "^5.7.3"
  }
}
